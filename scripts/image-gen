#!/usr/bin/env bash
set -euo pipefail

PY=${PYTHON_IMAGE_GEN:-/opt/homebrew/bin/python3.11}
SCRIPT=/opt/homebrew/lib/node_modules/openclaw/skills/openai-image-gen/scripts/gen.py

if [[ ! -x "$PY" ]]; then
  echo "python runtime not found: $PY" >&2
  exit 1
fi

if [[ ! -f "$SCRIPT" ]]; then
  echo "image gen script not found: $SCRIPT" >&2
  exit 1
fi

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  exec "$PY" "$SCRIPT" "$@"
fi

if [[ -z "${OPENAI_API_KEY:-}" ]]; then
  echo "OPENAI_API_KEY is not set." >&2
  echo "Example:" >&2
  echo "  export OPENAI_API_KEY='sk-...your key...'" >&2
  echo "Then run this command again." >&2
  exit 2
fi

exec "$PY" "$SCRIPT" "$@"
